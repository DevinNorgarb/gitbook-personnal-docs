{
  "name": "gitbook-personnal-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "docs:gen-index": "node scripts/sync-index-from-readme.mjs",
    "docs:gen-section-indexes": "node scripts/sync-section-indexes-from-summary.mjs",
    "docs:gen-topic-links": "node scripts/sync-topic-links.mjs",
    "docs:gen-sidebar": "node scripts/summary-to-vitepress-sidebar.mjs",
    "docs:check-sidebar": "node scripts/check-sidebar-drift.mjs",
    "docs:check-generated": "node scripts/check-generated-drift.mjs",
    "docs:test": "node --test scripts/navigation.test.mjs scripts/audit-markdown.test.mjs scripts/section-index.test.mjs scripts/topic-links.test.mjs",
    "docs:prep": "npm run docs:gen-section-indexes && npm run docs:gen-topic-links && npm run docs:gen-index && npm run docs:gen-sidebar",
    "docs:dev": "npm run docs:prep && vitepress dev .",
    "docs:build": "vitepress build .",
    "docs:preview": "vitepress preview .",
    "docs:audit": "node scripts/docs-audit.mjs",
    "docs:audit-assets": "node scripts/audit-asset-refs.mjs"
  },
  "devDependencies": {
    "vitepress": "^1.6.3",
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@sentry/vue": "^10.56.0"
  }
}
